    "/addons/{brand}/{extRef}/mail/{nextcloudUserId}/apppwd/{appname}": {
      "post": {
        "tags": [
          "MailConfigurationAPI"
        ],
        "summary": "A new password for provided appname will be set and returned",
        "operationId": "setAppPassword",
        "parameters": [
          {
            "name": "brand",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "IONOS"
              ]
            }
          },
          {
            "name": "extRef",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nextcloudUserId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "appname",
            "in": "path",
            "description": "app passwords are created for a specific app label\n * for nextcloud we'll support two different app passwords that can be created for the mail account:\n * - 'nextcloud_workspace' for the nextcloud workspace app\n * - 'nextcloud_workspace_user' for additonal user credentials that can be used to connect to the mail account from any other mail client",
            "required": true,
            "schema": {
              "type": "string",
              "description": "app passwords are created for a specific app label\n * for nextcloud we'll support two different app passwords that can be created for the mail account:\n * - 'nextcloud_workspace' for the nextcloud workspace app\n * - 'nextcloud_workspace_user' for additonal user credentials that can be used to connect to the mail account from any other mail client",
              "enum": [
                "NEXTCLOUD_WORKSPACE",
                "NEXTCLOUD_WORKSPACE_USER"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "returns the generated password. If a password for the appname already existed it will be replaced.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
